<%- await include('parts/header.ejs', locals) %>


<style>
    /* ═══════════════════════════════════════════════════════
       vibeSM Cosmic Master Actions — Frosted Cockpit Design
       ═══════════════════════════════════════════════════════ */

    .vibe-master-wrapper {
        max-width: 820px;
        margin: 0 auto;
        padding: 10px 0 30px;
    }

    /* Warning Banners */
    .vibe-alert {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 18px;
        border-radius: 10px;
        margin-bottom: 16px;
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.85rem;
        font-weight: 500;
        backdrop-filter: blur(12px);
    }
    .vibe-alert-warning {
        background: rgba(245, 158, 11, 0.08);
        border: 1px solid rgba(245, 158, 11, 0.2);
        color: rgb(251, 191, 36);
    }
    .vibe-alert-icon {
        flex-shrink: 0;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 0.7rem;
    }
    .vibe-alert-warning .vibe-alert-icon {
        background: rgba(245, 158, 11, 0.2);
        color: rgb(251, 191, 36);
    }

    /* Tab Navigation */
    .vibe-tabs {
        display: flex;
        gap: 4px;
        padding: 6px;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        margin-bottom: 24px;
    }
    .vibe-tab {
        flex: 1;
        padding: 10px 16px;
        text-align: center;
        border-radius: 8px;
        border: none;
        background: transparent;
        color: rgba(255, 255, 255, 0.5);
        font-family: 'Space Grotesk', sans-serif !important;
        font-weight: 600;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .vibe-tab:hover {
        color: rgba(255, 255, 255, 0.75);
        background: rgba(255, 255, 255, 0.04);
    }
    .vibe-tab.active {
        background: rgba(255, 255, 255, 0.06);
        color: #ffffff;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    }

    /* Content Cards */
    .vibe-panel {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 14px;
        padding: 28px;
        display: none;
    }
    .vibe-panel.active {
        display: block;
        animation: vibeFadeIn 0.3s ease-out;
    }
    @keyframes vibeFadeIn {
        from { opacity: 0; transform: translateY(6px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Section Item */
    .vibe-section {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 20px;
        padding: 20px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    }
    .vibe-section:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }
    .vibe-section:first-child {
        padding-top: 0;
    }
    .vibe-section-content {
        flex: 1;
    }
    .vibe-section-title {
        font-family: 'Outfit', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        color: #ffffff;
        margin-bottom: 6px;
    }
    .vibe-section-desc {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.82rem;
        color: rgba(255, 255, 255, 0.55);
        line-height: 1.6;
    }
    .vibe-section-desc code {
        background: rgba(255, 255, 255, 0.06);
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.78rem;
        color: rgb(244, 114, 182);
    }
    .vibe-section-desc a {
        color: rgb(244, 63, 94) !important;
        font-weight: 600;
        text-decoration: underline;
        text-underline-offset: 3px;
    }
    .vibe-section-desc a:hover {
        color: rgb(251, 113, 133) !important;
    }
    .vibe-section-action {
        flex-shrink: 0;
        display: flex;
        align-items: center;
    }

    /* Buttons */
    .vibe-btn {
        padding: 9px 18px;
        border-radius: 8px;
        border: none;
        font-family: 'Space Grotesk', sans-serif;
        font-weight: 600;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        white-space: nowrap;
    }
    .vibe-btn:active:not(:disabled) {
        transform: scale(0.97);
    }
    .vibe-btn:disabled {
        opacity: 0.35;
        cursor: not-allowed;
    }
    .vibe-btn-ghost {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.75);
    }
    .vibe-btn-ghost:hover:not(:disabled) {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.15);
        color: #ffffff;
    }
    .vibe-btn-danger {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        color: rgb(248, 113, 113);
    }
    .vibe-btn-danger:hover:not(:disabled) {
        background: rgba(239, 68, 68, 0.2);
        border-color: rgba(239, 68, 68, 0.35);
        color: #ffffff;
    }

    /* Moved Notice */
    .vibe-moved-notice {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 6px;
        background: rgba(245, 158, 11, 0.06);
        border: 1px solid rgba(245, 158, 11, 0.12);
        color: rgba(245, 158, 11, 0.8);
        font-size: 0.78rem;
        font-weight: 500;
    }

    /* Form styling */
    .vibe-form-group {
        display: flex;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 18px;
    }
    .vibe-form-label {
        flex: 0 0 110px;
        padding-top: 10px;
        font-family: 'Outfit', sans-serif;
        font-size: 0.82rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.8);
        text-align: right;
    }
    .vibe-form-field {
        flex: 1;
    }
    .vibe-select {
        width: 100%;
        padding: 10px 14px;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: #ffffff;
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.85rem;
        appearance: none;
        -webkit-appearance: none;
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='rgba(255,255,255,0.4)' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right 12px center;
        background-size: 16px;
        padding-right: 36px;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .vibe-select:focus {
        outline: none;
        border-color: rgba(244, 63, 94, 0.4);
        box-shadow: 0 0 0 3px rgba(244, 63, 94, 0.15);
    }
    .vibe-select option {
        background: #1a1b1e;
        color: #ffffff;
    }
    .vibe-form-hint {
        margin-top: 6px;
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.35);
        line-height: 1.5;
    }

    /* Alert boxes inside panels */
    .vibe-panel-alert {
        padding: 14px 18px;
        border-radius: 10px;
        margin-bottom: 22px;
        text-align: center;
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.82rem;
        font-weight: 500;
    }
    .vibe-panel-alert-warning {
        background: rgba(245, 158, 11, 0.06);
        border: 1px solid rgba(245, 158, 11, 0.15);
        color: rgb(251, 191, 36);
    }

    /* Submit area */
    .vibe-submit-area {
        display: flex;
        justify-content: center;
        padding-top: 20px;
        margin-top: 10px;
        border-top: 1px solid rgba(255, 255, 255, 0.04);
    }

    @media only screen and (max-width: 768px) {
        .vibe-form-group {
            flex-direction: column;
            gap: 6px;
        }
        .vibe-form-label {
            flex: none;
            text-align: left;
            padding-top: 0;
        }
        .vibe-section {
            flex-direction: column;
            gap: 12px;
        }
    }
</style>


<div class="vibe-master-wrapper">
    <% if (!isMasterAdmin) { %>
        <div class="vibe-alert vibe-alert-warning">
            <span class="vibe-alert-icon">!</span>
            You <strong>MUST</strong> be the Master Admin to use the options below.
        </div>
    <% } %>
    <% if (!isWebInterface) { %>
        <div class="vibe-alert vibe-alert-warning">
            <span class="vibe-alert-icon">!</span>
            These functions are disabled for the in-game menu. Please use the web version.
        </div>
    <% } %>

    <!-- Tab Navigation -->
    <div class="vibe-tabs" id="vibeTabNav">
        <button class="vibe-tab active" data-tab="general">General</button>
        <button class="vibe-tab" data-tab="cleandb">Clean Database</button>
        <button class="vibe-tab" data-tab="revokewl">Revoke Whitelists</button>
        <button class="vibe-tab" data-tab="artifacts">Artifacts Updater</button>
    </div>

    <!-- ═══ General Tab ═══ -->
    <div class="vibe-panel active" id="panel-general">
        <div class="vibe-section">
            <div class="vibe-section-content">
                <div class="vibe-section-title">Backup Database</div>
                <div class="vibe-section-desc">
                    Download a copy of the <code>playersDB.json</code> file containing all players and actions (bans, warns and whitelists). You should do this every once in a while.
                </div>
            </div>
            <div class="vibe-section-action">
                <button class="vibe-btn vibe-btn-danger" id="general-btnBackupDatabase" <%= disableActions %>>
                    Backup Database
                </button>
            </div>
        </div>
    </div>

    <!-- ═══ Clean Database Tab ═══ -->
    <div class="vibe-panel" id="panel-cleandb">
        <div class="vibe-panel-alert vibe-panel-alert-warning">
            <strong>⚠ Warning:</strong> This action is irreversible. We strongly suggest that you save a database backup first.
        </div>

        <div class="vibe-form-group">
            <label class="vibe-form-label" for="cleandb-players">Players</label>
            <div class="vibe-form-field">
                <select id="cleandb-players" class="vibe-select" name="players" required>
                    <option value="none">none</option>
                    <option value="60d" selected>inactive over 60 days</option>
                    <option value="30d">inactive over 30 days</option>
                    <option value="15d">inactive over 15 days</option>
                </select>
                <div class="vibe-form-hint">
                    Remove players based on how much time since they last connected. This will not remove players with saved notes or erase bans/warns/whitelist logs.
                </div>
            </div>
        </div>

        <div class="vibe-form-group">
            <label class="vibe-form-label" for="cleandb-bans">Bans</label>
            <div class="vibe-form-field">
                <select id="cleandb-bans" class="vibe-select" name="bans" required>
                    <option value="none">none</option>
                    <option value="revoked" selected>revoked</option>
                    <option value="revokedExpired">revoked or expired</option>
                    <option value="all">⚠ REMOVE ALL BANS</option>
                </select>
                <div class="vibe-form-hint">
                    Remove expired or revoked bans from the database.
                </div>
            </div>
        </div>

        <div class="vibe-form-group">
            <label class="vibe-form-label" for="cleandb-warns">Warns</label>
            <div class="vibe-form-field">
                <select id="cleandb-warns" class="vibe-select" name="warns" required>
                    <option value="none">none</option>
                    <option value="revoked">revoked</option>
                    <option value="30d" selected>older than 30 days</option>
                    <option value="15d">older than 15 days</option>
                    <option value="7d">older than 7 days</option>
                    <option value="all">⚠ REMOVE ALL WARNS</option>
                </select>
                <div class="vibe-form-hint">
                    Remove old or revoked warns from the database.
                </div>
            </div>
        </div>

        <div class="vibe-form-group">
            <label class="vibe-form-label" for="cleandb-hwids">HWIDs</label>
            <div class="vibe-form-field">
                <select id="cleandb-hwids" class="vibe-select" name="hwids" required>
                    <option value="none" selected>none</option>
                    <option value="players">from players</option>
                    <option value="bans">from bans</option>
                    <option value="all">⚠ REMOVE ALL HWIDS</option>
                </select>
                <div class="vibe-form-hint">
                    Player HWIDs are tied to the server owner. If you change your <code>sv_licenseKey</code> to one owned by another person, it is recommended that you wipe the existing HWIDs.
                </div>
            </div>
        </div>

        <div class="vibe-submit-area">
            <button class="vibe-btn vibe-btn-danger" id="cleandb-submitButton" <%= disableActions %>>
                🗑 Clean Database
            </button>
        </div>
    </div>

    <!-- ═══ Revoke Whitelists Tab ═══ -->
    <div class="vibe-panel" id="panel-revokewl">
        <div class="vibe-form-group">
            <label class="vibe-form-label" for="revokewl-filter">Filter</label>
            <div class="vibe-form-field">
                <select id="revokewl-filter" class="vibe-select" name="filter" required>
                    <option value="30d" selected>players that haven't joined in the last 30 days</option>
                    <option value="15d">players that haven't joined in the last 15 days</option>
                    <option value="7d">players that haven't joined in the last 7 days</option>
                    <option value="all">⚠ REVOKE ALL WHITELISTS</option>
                </select>
                <div class="vibe-form-hint">
                    Revoke whitelist from players that have not joined the server in the last X days. <br>
                    <strong>Note:</strong> This only applies to license whitelist, not Discord member or Discord role whitelist.
                </div>
            </div>
        </div>

        <div class="vibe-submit-area">
            <button class="vibe-btn vibe-btn-danger" id="revokewl-submitButton" <%= disableActions %>>
                ✕ Revoke Whitelists
            </button>
        </div>
    </div>

    <!-- ═══ Artifacts Updater Tab ═══ -->
    <div class="vibe-panel" id="panel-artifacts">
        <div class="vibe-panel-alert vibe-panel-alert-warning" style="text-align: left; line-height: 1.6;">
            <strong>ℹ Artifacts Updater:</strong> Downloads the specified FXServer artifacts build, extracts it to a parallel directory (e.g. <code>server_updated_&lt;build&gt;</code>), and copies your custom <strong>vibeSM</strong> resource over standard txAdmin. You will then manually rename/swap folders and restart the host.
        </div>

        <div class="vibe-form-group">
            <label class="vibe-form-label" for="artifacts-build">Select Build</label>
            <div class="vibe-form-field">
                <select id="artifacts-build" class="vibe-select" required>
                    <option value="recommended" selected>Latest Recommended (<%= versions.recommended %>)</option>
                    <option value="optional">Latest Optional (<%= versions.optional %>)</option>
                    <option value="latest">Latest (<%= versions.latest %>)</option>
                    <option value="custom">Custom Build Number...</option>
                </select>
                <div class="vibe-form-hint">
                    Choose the target FXServer build channel to prepare.
                </div>
            </div>
        </div>

        <div class="vibe-form-group" id="artifacts-custom-group" style="display: none;">
            <label class="vibe-form-label" for="artifacts-custom-number">Build Number</label>
            <div class="vibe-form-field">
                <input id="artifacts-custom-number" type="number" class="vibe-select" placeholder="e.g. 7290" style="background-image: none; padding-right: 14px;" />
                <div class="vibe-form-hint">
                    Specify the numeric build number from runtime.fivem.net.
                </div>
            </div>
        </div>

        <div id="artifacts-progress-card" style="display: none; margin-top: 20px; padding: 18px; background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 10px;">
            <div style="font-weight: 600; color: #fff; font-size: 0.85rem; margin-bottom: 8px; font-family: 'Outfit', sans-serif;">Status / Log Output:</div>
            <div id="artifacts-progress-log" style="font-family: 'Space Grotesk', sans-serif; font-size: 0.78rem; color: rgba(255,255,255,0.7); line-height: 1.6;">
                Ready to start...
            </div>
            
            <div id="artifacts-progress-container" style="width: 100%; height: 8px; background: rgba(255,255,255,0.05); border-radius: 4px; overflow: hidden; margin-top: 12px; margin-bottom: 12px;">
                <div id="artifacts-progress-bar" style="width: 0%; height: 100%; background: rgb(244, 63, 94); transition: width 0.3s ease; border-radius: 4px;"></div>
            </div>
            
            <div id="artifacts-instructions-banner" style="display: none; margin-top: 15px; padding: 12px; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); border-radius: 6px; color: #10b981; font-size: 0.8rem; line-height: 1.6;">
                <strong>✔ Artifacts Prepared Successfully!</strong><br>
                1. Stop your FXServer host process.<br>
                2. Rename your active <code>server</code> directory to <code>server_backup</code>.<br>
                3. Rename <code><span id="artifacts-new-path">server_updated_xxx</span></code> to <code>server</code>.<br>
                4. Restart the FXServer host. Your custom vibeSM configurations are fully preserved!
            </div>
        </div>

        <div class="vibe-submit-area">
            <button class="vibe-btn vibe-btn-danger" id="artifacts-submitButton" <%= disableActions %>>
                ⚡ Prepare Artifacts
            </button>
        </div>
    </div>
</div>


<%- await include('parts/footer.ejs', locals) %>


<script>
    // Local scope compatibility mapping to avoid cache issues
    const txAdminConfirm = window.txAdminConfirm || window.vibeSMConfirm;
    const txAdminAlert = window.txAdminAlert || window.vibeSMAlert;
    const txAdminPrompt = window.txAdminPrompt || window.vibeSMPrompt;

    //============================================== Tab switching
    (()=>{
        const tabs = document.querySelectorAll('.vibe-tab');
        const panels = document.querySelectorAll('.vibe-panel');

        // Read hash from URL
        const hashMap = { '#cleandb': 'cleandb', '#revokewl': 'revokewl', '#artifacts': 'artifacts' };
        const initialTab = hashMap[window.location.hash] || 'general';

        function switchTab(tabId) {
            tabs.forEach(t => t.classList.toggle('active', t.dataset.tab === tabId));
            panels.forEach(p => p.classList.toggle('active', p.id === `panel-${tabId}`));
        }

        switchTab(initialTab);

        tabs.forEach(tab => {
            tab.addEventListener('click', () => switchTab(tab.dataset.tab));
        });
    })();

    //============================================== General
    (()=>{
        const generalBtnBackupDatabase = document.getElementById('general-btnBackupDatabase');
        generalBtnBackupDatabase.onclick = async () => {
            window.location = 'masterActions/backupDatabase';
        }
    })();


    //============================================== Clean Database
    (()=>{
        const frmPlayers = document.getElementById('cleandb-players');
        const frmBans = document.getElementById('cleandb-bans');
        const frmWarns = document.getElementById('cleandb-warns');
        const frmHwids = document.getElementById('cleandb-hwids');
        const cleandbSubmitBtn = document.getElementById('cleandb-submitButton');

        cleandbSubmitBtn.onclick = async (event) => {
            //Validate options
            const changes = [];
            if(frmPlayers.value !== 'none'){
                changes.push(`Remove players ${frmPlayers.options[frmPlayers.selectedIndex].text}.`);
            }
            if(frmBans.value !== 'none'){
                changes.push(`Remove bans ${frmBans.options[frmBans.selectedIndex].text}.`);
            }
            if(frmWarns.value !== 'none'){
                changes.push(`Remove warns ${frmWarns.options[frmWarns.selectedIndex].text}.`);
            }
            if(frmHwids.value !== 'none'){
                changes.push(`Remove HWIDs ${frmHwids.options[frmHwids.selectedIndex].text}.`);
            }
            if(!changes.length){
                return $.notify({ message: 'You need to select at least one option.' }, {type: 'danger'});
            }

            //Confirm action
            const confirmOptions = {
                title: 'Are you sure wou want to:',
                content: '<ul>' + changes.map(x => `<li>${x}</li>`).join('\n') + '</ul>'
            }
            if(!await txAdminConfirm(confirmOptions)) return;
            
            //Send API request
            txAdminAPI({
                type: "POST",
                url: `/masterActions/cleanDatabase`,
                data: {
                    players: frmPlayers.value,
                    bans: frmBans.value,
                    warns: frmWarns.value,
                    hwids: frmHwids.value,
                },
                timeout: REQ_TIMEOUT_LONG,
                success: function (data) {
                    if(data.error){
                        return txAdminAlert({
                            title: 'Error:',
                            modalColor: 'red',
                            content: data.error
                        });
                    }else{
                        return txAdminAlert({
                            title: 'Result:',
                            content: `<b>Players deleted: ${data.playersRemoved}</b> <br>
                                <b>Actions deleted: ${data.actionsRemoved}</b> <br>
                                <b>HWIDs deleted: ${data.hwidsRemoved}</b> <br>
                                Process finished in ${data.msElapsed}ms.`
                        });
                    }
                },
                error: function (xmlhttprequest, textstatus, message) {
                    return txAdminAlert({
                        title: 'Error:',
                        modalColor: 'red',
                        content: message
                    });
                }
            });
        }
    })();


    //============================================== Revoke Whitelists
    (()=>{
        const frmFilter = document.getElementById('revokewl-filter');
        const revokewlSubmitBtn = document.getElementById('revokewl-submitButton');

        revokewlSubmitBtn.onclick = async (event) => {
            //Confirm action
            const actionText = (frmFilter.value === 'all')
                ? `Revoke ALL Whitelists.`
                : `Revoke Whitelist from all players that have not joined in the past ${frmFilter.value}.`;
            const confirmOptions = {
                title: 'Are you sure wou want to:',
                content: actionText
            }
            if(!await txAdminConfirm(confirmOptions)) return;
            
            //Send API request
            txAdminAPI({
                type: "POST",
                url: `/masterActions/revokeWhitelists`,
                data: {
                    filter: frmFilter.value,
                },
                timeout: REQ_TIMEOUT_LONG,
                success: function (data) {
                    if(data.error){
                        return txAdminAlert({
                            title: 'Error:',
                            modalColor: 'red',
                            content: data.error
                        });
                    }else{
                        return txAdminAlert({
                            title: 'Result:',
                            content: `<b>Whitelists revoked: ${data.cntRemoved}</b> <br>
                                Process finished in ${data.msElapsed}ms.`
                        });
                    }
                },
                error: function (xmlhttprequest, textstatus, message) {
                    return txAdminAlert({
                        title: 'Error:',
                        modalColor: 'red',
                        content: message
                    });
                }
            });
        }
    })();

    //============================================== Artifacts Updater
    (() => {
        const buildSelect = document.getElementById('artifacts-build');
        const customGroup = document.getElementById('artifacts-custom-group');
        const customNumber = document.getElementById('artifacts-custom-number');
        const submitBtn = document.getElementById('artifacts-submitButton');
        
        const progressCard = document.getElementById('artifacts-progress-card');
        const progressLog = document.getElementById('artifacts-progress-log');
        const instructionsBanner = document.getElementById('artifacts-instructions-banner');
        const newPathSpan = document.getElementById('artifacts-new-path');

        buildSelect.addEventListener('change', () => {
            customGroup.style.display = (buildSelect.value === 'custom') ? 'flex' : 'none';
        });

        let pollInterval = null;

        function startPolling() {
            if (pollInterval) clearInterval(pollInterval);
            pollInterval = setInterval(() => {
                txAdminAPI({
                    type: "POST",
                    url: '/masterActions/getArtifactsUpdateStatus',
                    success: function (status) {
                        if (status.step) {
                            progressLog.innerHTML = `<strong>Step:</strong> ${status.step}`;
                        }
                        if (status.progress !== undefined) {
                            const bar = document.getElementById('artifacts-progress-bar');
                            if (bar) bar.style.width = status.progress + '%';
                        }
                        if (status.error) {
                            progressLog.innerHTML = `<span style="color: #ef4444;"><strong>Error:</strong> ${status.error}</span>`;
                            submitBtn.disabled = false;
                            clearInterval(pollInterval);
                        }
                        if (status.success) {
                            progressLog.innerHTML = `<span style="color: #10b981;"><strong>Status:</strong> Ready at ${status.targetPath}</span>`;
                            newPathSpan.textContent = status.targetPath;
                            instructionsBanner.style.display = 'block';
                            submitBtn.disabled = false;
                            clearInterval(pollInterval);
                        }
                    },
                    error: function (xmlhttprequest, textstatus, message) {
                        console.error('Failed to poll status', message);
                    }
                });
            }, 2000);
        }

        submitBtn.onclick = async () => {
            const targetChannel = (buildSelect.value === 'custom') ? customNumber.value.trim() : buildSelect.value;
            if (!targetChannel) {
                return $.notify({ message: 'Please enter a valid build number.' }, {type: 'danger'});
            }

            // Confirm action
            const confirmOptions = {
                title: 'Confirm Artifact Preparation:',
                content: `This will download, verify, and extract FXServer artifacts for selection: <strong>${targetChannel}</strong>. Proceed?`
            };
            if (!await txAdminConfirm(confirmOptions)) return;

            submitBtn.disabled = true;
            progressCard.style.display = 'block';
            instructionsBanner.style.display = 'none';
            progressLog.textContent = 'Triggering preparation on server...';

            txAdminAPI({
                type: "POST",
                url: `/masterActions/triggerArtifactsUpdate`,
                data: {
                    channel: targetChannel
                },
                success: function (data) {
                    if (data.error) {
                        progressLog.innerHTML = `<span style="color: #ef4444;"><strong>Error:</strong> ${data.error}</span>`;
                        submitBtn.disabled = false;
                    } else {
                        startPolling();
                    }
                },
                error: function (xmlhttprequest, textstatus, message) {
                    progressLog.innerHTML = `<span style="color: #ef4444;"><strong>Error:</strong> ${message}</span>`;
                    submitBtn.disabled = false;
                }
            });
        };
    })();
</script>
